{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"],
    "rootDir": "./src",
    "outDir": "./dist/main",
    "composite": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo.main"
  },
  "include": ["src/main/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["src/renderer/**/*", "src/preload/**/*", "tests/**/*"]
}
