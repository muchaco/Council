{
  "name": "council3",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/main/index.js",
  "scripts": {
    "clean": "rm -rf dist coverage",
    "dev": "bun run dev:electron",
    "dev:renderer": "vite --port 5173 --strictPort",
    "dev:main:watch": "bunx tsc -w -p tsconfig.main.json",
    "dev:preload:watch": "bunx tsc -w -p tsconfig.preload.json",
    "dev:electron:start": "bunx wait-on tcp:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 bunx electron --disable-gpu --disable-software-rasterizer .",
    "dev:electron": "bun run build:main && bun run build:preload && bunx concurrently -k -n renderer,main,preload,electron -c cyan,green,yellow,magenta \"bun run dev:renderer\" \"bun run dev:main:watch\" \"bun run dev:preload:watch\" \"bun run dev:electron:start\"",
    "tool:electron": "sh -c '[ -z \"$DISPLAY\" ] && xvfb-run -a node scripts/diagnostics/electron-diagnostic.mjs \"$@\" || node scripts/diagnostics/electron-diagnostic.mjs \"$@\"' --",
    "diag:electron": "bun run tool:electron -- --scenario scripts/diagnostics/scenarios/settings-smoke.json",
    "scenario:quantum-gravity": "node scripts/diagnostics/quantum-gravity-debate.mjs",
    "rebuild:native": "bunx electron-rebuild -f -w better-sqlite3,keytar",
    "postinstall": "node node_modules/electron/install.js",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check .",
    "typecheck": "bunx tsc -b tsconfig.main.json tsconfig.preload.json tsconfig.renderer.json tsconfig.scripts.json",
    "build": "bun run clean && bun run build:main && bun run build:preload && bun run build:renderer",
    "build:main": "bunx tsc --pretty false -p tsconfig.main.json",
    "build:preload": "bunx tsc --pretty false -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "package:linux": "bun run build && bun run rebuild:native && bunx electron-builder --linux AppImage --publish never",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "bun run test:coverage:unit && bun run test:coverage:integration",
    "test:coverage:unit": "vitest run --config vitest.unit.config.ts --coverage",
    "test:coverage:integration": "vitest run --config vitest.integration.config.ts --coverage",
    "check:coverage-guardrails": "bun run scripts/verify-coverage-guardrails.ts",
    "check:boundaries": "bun run scripts/check-boundaries.ts",
    "check:packaging-pipeline": "bun run scripts/verify-packaging-pipeline.ts",
    "trace:generate": "bun run scripts/generate-requirement-traceability.ts",
    "check:traceability": "bun run scripts/check-requirement-traceability.ts",
    "db:migrate:verify": "bun run scripts/verify-migrations.ts",
    "check:required-scripts": "bun run scripts/verify-required-scripts.ts",
    "logs:tail": "bun run scripts/logs.ts tail",
    "logs:search": "bun run scripts/logs.ts search",
    "logs:filter": "bun run scripts/logs.ts filter",
    "logs:files": "bun run scripts/logs.ts files",
    "logs:path": "bun run scripts/logs.ts path"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "better-sqlite3": "^11.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "keytar": "^7.9.0",
    "lucide-react": "^0.575.0",
    "neverthrow": "^8.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.24",
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "playwright": "^1.52.0",
    "postcss": "^8.5.6",
    "tailwindcss": "3",
    "typescript": "^5.8.2",
    "vite": "^6.1.1",
    "vitest": "^3.0.8"
  },
  "build": {
    "appId": "com.council3.app",
    "productName": "Council3",
    "directories": {
      "output": "dist/release"
    },
    "files": ["dist/main/**/*", "dist/preload/**/*", "dist/renderer/**/*", "package.json"],
    "asarUnpack": ["node_modules/better-sqlite3/**/*", "node_modules/keytar/**/*"],
    "linux": {
      "target": ["AppImage"],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "category": "Utility"
    }
  }
}
